import React, { useState, useEffect } from 'react';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { 
  Download, 
  RefreshCw, 
  FileSpreadsheet,
  DollarSign 
} from 'lucide-react';

const DailyFinanceTracker = () => {
  const [accounts, setAccounts] = useState([
    {
      id: 'checking',
      name: 'Main Checking',
      balanceHistory: [],
      dailyTransactions: []
    },
    {
      id: 'savings',
      name: 'Savings Account',
      balanceHistory: [],
      dailyTransactions: []
    }
  ]);

  const [importMethod, setImportMethod] = useState(null);

  // Simplified import methods
  const importMethods = [
    {
      id: 'csv',
      name: 'CSV Upload',
      icon: <FileSpreadsheet className="mr-2" />,
      description: 'Upload daily bank statement CSV files'
    },
    {
      id: 'screenshot',
      name: 'Screenshot Import',
      icon: <Download className="mr-2" />,
      description: 'Use OCR to extract balance and transaction details from screenshots'
    }
  ];

  // Manual daily balance entry component
  const DailyBalanceEntry = ({ account, onAddBalance }) => {
    const [balance, setBalance] = useState('');
    const [date, setDate] = useState(new Date().toISOString().split('T')[0]);

    const handleSubmit = () => {
      if (balance) {
        onAddBalance(account.id, {
          date,
          amount: parseFloat(balance)
        });
        setBalance('');
      }
    };

    return (
      <Card className="w-full max-w-md">
        <CardHeader>
          <CardTitle className="flex items-center">
            <DollarSign className="mr-2" /> {account.name} Daily Balance
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div className="flex space-x-2">
            <input 
              type="date"
              value={date}
              onChange={(e) => setDate(e.target.value)}
              className="flex-shrink-0 p-2 border rounded"
            />
            <input 
              type="number"
              placeholder="Balance"
              value={balance}
              onChange={(e) => setBalance(e.target.value)}
              className="flex-grow p-2 border rounded"
            />
            <Button onClick={handleSubmit}>Add</Button>
          </div>
        </CardContent>
      </Card>
    );
  };

  // Balance Tracking Component
  const BalanceTracking = () => {
    const addDailyBalance = (accountId, balanceEntry) => {
      setAccounts(prevAccounts => 
        prevAccounts.map(account => 
          account.id === accountId 
            ? {
                ...account,
                balanceHistory: [
                  ...account.balanceHistory, 
                  balanceEntry
                ].sort((a, b) => new Date(a.date) - new Date(b.date))
              }
            : account
        )
      );
    };

    return (
      <div className="space-y-4">
        <h2 className="text-xl font-bold">Daily Balance Tracking</h2>
        {accounts.map(account => (
          <div key={account.id}>
            <DailyBalanceEntry 
              account={account} 
              onAddBalance={addDailyBalance} 
            />
            {account.balanceHistory.length > 0 && (
              <div className="mt-4">
                <h3 className="font-semibold">Recent Balances</h3>
                <ul className="space-y-1 text-sm">
                  {account.balanceHistory
                    .slice(-5)
                    .map((entry, index) => (
                      <li key={index} className="flex justify-between">
                        <span>{entry.date}</span>
                        <span>${entry.amount.toFixed(2)}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    );
  };

  // Import Method Selection
  const ImportMethodSelector = () => {
    return (
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center">
            <RefreshCw className="mr-2" /> Import Methods
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div className="grid md:grid-cols-2 gap-4">
            {importMethods.map(method => (
              <Button 
                key={method.id}
                variant="outline"
                className="flex items-center justify-start p-4 h-auto"
                onClick={() => setImportMethod(method.id)}
              >
                {method.icon}
                <div className="text-left">
                  <h3 className="font-semibold">{method.name}</h3>
                  <p className="text-xs text-gray-500">{method.description}</p>
                </div>
              </Button>
            ))}
          </div>
        </CardContent>
      </Card>
    );
  };

  // Render
  return (
    <div className="container mx-auto p-4 space-y-6">
      <h1 className="text-2xl font-bold">Streamlined Finance Tracking</h1>
      
      {/* Import Method Selection */}
      <ImportMethodSelector />

      {/* Daily Balance Tracking */}
      <BalanceTracking />
    </div>
  );
};

export default DailyFinanceTracker;
